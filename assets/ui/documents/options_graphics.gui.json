{
 "format": 1,
 "kind": "petramond:options_graphics",
 "class": "screen",
 "root": {
  "type": "frame",
  "layout": {
   "w": {
    "grow": 1
   },
   "h": {
    "grow": 1
   },
   "align": "center",
   "justify": "center"
  },
  "children": [
   {
    "type": "image",
    "image": "../../textures/gui/screenshot.png",
    "fit": "cover",
    "layout": {
     "w": {
      "grow": 1
     },
     "h": {
      "grow": 1
     },
     "abs": {
      "x": 0,
      "y": 0
     }
    },
    "bind": {
     "visible": "show_backdrop"
    }
   },
   {
    "type": "column",
    "style": "panel.large",
    "layout": {
     "w": 250,
     "pad": [
      10,
      8,
      10,
      10
     ],
     "gap": 7,
     "align": "stretch"
    },
    "children": [
     {
      "type": "row",
      "layout": {
       "justify": "center"
      },
      "children": [
       {
        "type": "label",
        "text": "Graphics",
        "scale": 2
       }
      ]
     },
     {
      "type": "spacer",
      "layout": {
       "h": 2
      }
     },
     {
      "type": "row",
      "layout": {
       "gap": 4,
       "align": "center"
      },
      "children": [
       {
        "type": "label",
        "text": "View Distance",
        "layout": {
         "w": 78
        }
       },
       {
        "type": "slider",
        "id": "view_distance",
        "min": 4,
        "max": 48,
        "step": 1,
        "bind": {
         "value": "view_distance"
        },
        "layout": {
         "w": {
          "grow": 1
         },
         "min_w": 80
        }
       },
       {
        "type": "label",
        "layout": {
         "w": 54
        },
        "bind": {
         "text": "vd_label"
        }
       }
      ]
     },
     {
      "type": "row",
      "layout": {
       "justify": "center"
      },
      "children": [
       {
        "type": "button",
        "id": "particles",
        "layout": {
         "w": 140
        },
        "bind": {
         "text": "particles_label"
        }
       }
      ]
     },
     {
      "type": "spacer",
      "layout": {
       "h": 2
      }
     },
     {
      "type": "row",
      "layout": {
       "justify": "center"
      },
      "children": [
       {
        "type": "button",
        "id": "back",
        "text": "Back",
        "layout": {
         "w": 130
        }
       }
      ]
     }
    ]
   }
  ]
 }
}