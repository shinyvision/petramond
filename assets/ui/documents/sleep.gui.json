{
    "format": 1,
    "kind": "llama:sleep",
    "class": "screen",
    "root": {
        "type": "frame",
        "layout": {
            "anchor": {
                "h": "center",
                "v": "end"
            },
            "margin": [
                0,
                0,
                0,
                28
            ],
            "gap": 6,
            "align": "center"
        },
        "children": [
            {
                "type": "label",
                "style": "label.muted",
                "bind": {
                    "text": "sleep_count",
                    "visible": "sleep_count_visible"
                }
            },
            {
                "type": "button",
                "id": "leave_bed",
                "text": "LEAVE BED",
                "layout": {
                    "w": 110
                }
            }
        ]
    }
