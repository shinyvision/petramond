{
 "format": 1,
 "kind": "petramond:options_controls",
 "class": "screen",
 "root": {
  "type": "frame",
  "layout": {
   "w": {
    "grow": 1
   },
   "h": {
    "grow": 1
   },
   "align": "center",
   "justify": "center"
  },
  "children": [
   {
    "type": "image",
    "image": "../../textures/gui/screenshot.png",
    "fit": "cover",
    "layout": {
     "w": {
      "grow": 1
     },
     "h": {
      "grow": 1
     },
     "abs": {
      "x": 0,
      "y": 0
     }
    },
    "bind": {
     "visible": "show_backdrop"
    }
   },
   {
    "type": "column",
    "style": "panel.large",
    "layout": {
     "w": 260,
     "pad": [
      10,
      8,
      10,
      10
     ],
     "gap": 6,
     "align": "stretch"
    },
    "children": [
     {
      "type": "row",
      "layout": {
       "justify": "center"
      },
      "children": [
       {
        "type": "label",
        "text": "Controls",
        "scale": 2
       }
      ]
     },
     {
      "type": "label",
      "style": "label.muted",
      "wrap": true,
      "layout": {
       "h": 16
      },
      "bind": {
       "text": "remap_hint"
      }
     },
     {
      "id": "controls_scroll",
      "type": "scroll",
      "axis": "vertical",
      "style": "panel.inset",
      "layout": {
       "h": 150,
       "min_h": 48,
       "pad": [
        1,
        1,
        1,
        1
       ]
      },
      "children": [
       {
        "id": "controls",
        "type": "list",
        "layout": {
         "align": "stretch"
        },
        "bind": {
         "items": "rows"
        },
        "children": [
         {
          "type": "column",
          "layout": {
           "align": "stretch"
          },
          "children": [
           {
            "type": "row",
            "layout": {
             "pad": [
              2,
              4,
              2,
              4
             ],
             "gap": 5,
             "align": "center"
            },
            "bind": {
             "visible": "is_header"
            },
            "children": [
             {
              "type": "image",
              "image": "pixel.png",
              "layout": {
               "w": {
                "grow": 1
               },
               "h": 1
              }
             },
             {
              "type": "label",
              "style": "label.muted",
              "bind": {
               "text": "label"
              }
             },
             {
              "type": "image",
              "image": "pixel.png",
              "layout": {
               "w": {
                "grow": 1
               },
               "h": 1
              }
             }
            ]
           },
           {
            "type": "row",
            "layout": {
             "pad": [
              2,
              1,
              2,
              1
             ],
             "gap": 4,
             "align": "center"
            },
            "bind": {
             "visible": "is_action"
            },
            "children": [
             {
              "type": "label",
              "layout": {
               "w": {
                "grow": 1
               }
              },
              "bind": {
               "text": "label"
              }
             },
             {
              "type": "button",
              "id": "bind",
              "layout": {
               "w": 92
              },
              "bind": {
               "text": "binding"
              }
             }
            ]
           }
          ]
         }
        ]
       }
      ]
     },
     {
      "type": "row",
      "layout": {
       "justify": "center"
      },
      "children": [
       {
        "type": "button",
        "id": "back",
        "text": "Back",
        "layout": {
         "w": 130
        }
       }
      ]
     }
    ]
   }
  ]
 }
}