{
    "format": 1,
    "kind": "petramond:world_settings",
    "class": "screen",
    "root": {
        "type": "frame",
        "layout": {
            "w": {
                "grow": 1
            },
            "h": {
                "grow": 1
            },
            "align": "center",
            "justify": "center"
        },
        "children": [
            {
                "type": "image",
                "image": "../../textures/gui/screenshot.png",
                "fit": "cover",
                "layout": {
                    "w": {
                        "grow": 1
                    },
                    "h": {
                        "grow": 1
                    },
                    "abs": {
                        "x": 0,
                        "y": 0
                    }
                }
            },
            {
                "type": "frame",
                "style": "panel.large",
                "layout": {
                    "w": 320,
                    "h": 260,
                    "pad": [
                        4,
                        2,
                        4,
                        4
                    ],
                    "gap": 4,
                    "align": "stretch"
                },
                "children": [
                    {
                        "type": "row",
                        "layout": {
                            "gap": 8,
                            "align": "center",
                            "justify": "center"
                        },
                        "children": [
                            {
                                "type": "label",
                                "text": "World Settings"
                            }
                        ]
                    },
                    {
                        "type": "row",
                        "layout": {
                            "gap": 5,
                            "align": "center",
                            "justify": "center"
                        },
                        "children": [
                            {
                                "type": "label",
                                "style": "label.muted",
                                "bind": {
                                    "text": "world_name",
                                    "visible": "not_renaming"
                                }
                            },
                            {
                                "id": "rename",
                                "type": "button",
                                "icon": "icon.edit",
                                "layout": {
                                    "w": 18,
                                    "h": 16
                                },
                                "bind": {
                                    "visible": "not_renaming"
                                }
                            }
                        ]
                    },
                    {
                        "type": "row",
                        "layout": {
                            "gap": 5,
                            "align": "center"
                        },
                        "bind": {
                            "visible": "renaming"
                        },
                        "children": [
                            {
                                "id": "rename_input",
                                "type": "text_input",
                                "max_chars": 48,
                                "layout": {
                                    "w": {
                                        "grow": 1
                                    }
                                },
                                "bind": {
                                    "text": "world_name"
                                }
                            },
                            {
                                "id": "rename_confirm",
                                "type": "button",
                                "text": "OK",
                                "layout": {
                                    "w": 30
                                },
                                "style": "button.success"
                            }
                        ]
                    },
                    {
                        "id": "tabs",
                        "type": "tab_bar",
                        "tabs": [
                            {
                                "key": "world",
                                "icon": "icon.tab_world",
                                "label": "World"
                            },
                            {
                                "key": "mods",
                                "icon": "icon.tab_mods",
                                "label": "Mods"
                            }
                        ],
                        "bind": {
                            "selected": "tab_sel"
                        }
                    },
                    {
                        "type": "frame",
                        "layout": {
                            "h": {
                                "grow": 1
                            },
                            "gap": 6,
                            "align": "stretch"
                        },
                        "bind": {
                            "visible": "tab_world"
                        },
                        "children": [
                            {
                                "type": "row",
                                "layout": {
                                    "pad": [
                                        3,
                                        1,
                                        3,
                                        1
                                    ],
                                    "gap": 8,
                                    "align": "center"
                                },
                                "bind": {
                                    "visible": "has_seed"
                                },
                                "children": [
                                    {
                                        "type": "label",
                                        "style": "label.muted",
                                        "text": "Seed"
                                    },
                                    {
                                        "type": "spacer",
                                        "layout": {
                                            "w": {
                                                "grow": 1
                                            }
                                        }
                                    },
                                    {
                                        "type": "label",
                                        "bind": {
                                            "text": "seed_text"
                                        }
                                    },
                                    {
                                        "id": "copy_seed",
                                        "type": "button",
                                        "icon": "icon.copy",
                                        "layout": {
                                            "w": 16,
                                            "h": 16
                                        }
                                    }
                                ]
                            },
                            {
                                "type": "row",
                                "layout": {
                                    "pad": [
                                        3,
                                        1,
                                        3,
                                        1
                                    ],
                                    "gap": 8,
                                    "align": "center"
                                },
                                "children": [
                                    {
                                        "type": "label",
                                        "style": "label.muted",
                                        "text": "World size"
                                    },
                                    {
                                        "type": "spacer",
                                        "layout": {
                                            "w": {
                                                "grow": 1
                                            }
                                        }
                                    },
                                    {
                                        "type": "label",
                                        "bind": {
                                            "text": "world_size"
                                        }
                                    }
                                ]
                            },
                            {
                                "type": "row",
                                "layout": {
                                    "pad": [
                                        3,
                                        1,
                                        3,
                                        1
                                    ],
                                    "gap": 8,
                                    "align": "center"
                                },
                                "children": [
                                    {
                                        "type": "label",
                                        "text": "Day length"
                                    },
                                    {
                                        "type": "spacer",
                                        "layout": {
                                            "w": {
                                                "grow": 1
                                            }
                                        }
                                    },
                                    {
                                        "type": "label",
                                        "style": "label.muted",
                                        "bind": {
                                            "text": "day_minutes_text"
                                        }
                                    },
                                    {
                                        "id": "day_minutes",
                                        "type": "slider",
                                        "min": 10.0,
                                        "max": 30.0,
                                        "step": 1.0,
                                        "layout": {
                                            "w": 90
                                        },
                                        "bind": {
                                            "value": "day_minutes"
                                        }
                                    }
                                ]
                            },
                            {
                                "type": "row",
                                "layout": {
                                    "pad": [
                                        3,
                                        1,
                                        3,
                                        1
                                    ],
                                    "gap": 8,
                                    "align": "center"
                                },
                                "children": [
                                    {
                                        "type": "column",
                                        "layout": {
                                            "gap": 2
                                        },
                                        "children": [
                                            {
                                                "type": "label",
                                                "text": "Keep inventory on death"
                                            },
                                            {
                                                "type": "label",
                                                "style": "label.muted",
                                                "text": "Your items stay with you when you die"
                                            }
                                        ]
                                    },
                                    {
                                        "type": "spacer",
                                        "layout": {
                                            "w": {
                                                "grow": 1
                                            }
                                        }
                                    },
                                    {
                                        "id": "keep_inventory",
                                        "type": "checkbox",
                                        "bind": {
                                            "value": "keep_inventory"
                                        }
                                    }
                                ]
                            },
                            {
                                "type": "row",
                                "layout": {
                                    "pad": [
                                        3,
                                        1,
                                        3,
                                        1
                                    ],
                                    "gap": 8,
                                    "align": "center"
                                },
                                "children": [
                                    {
                                        "type": "column",
                                        "layout": {
                                            "gap": 2
                                        },
                                        "children": [
                                            {
                                                "type": "label",
                                                "text": "Open to LAN on load"
                                            },
                                            {
                                                "type": "label",
                                                "style": "label.muted",
                                                "text": "Host on the local network automatically"
                                            }
                                        ]
                                    },
                                    {
                                        "type": "spacer",
                                        "layout": {
                                            "w": {
                                                "grow": 1
                                            }
                                        }
                                    },
                                    {
                                        "id": "auto_lan",
                                        "type": "checkbox",
                                        "bind": {
                                            "value": "auto_lan"
                                        }
                                    }
                                ]
                            },
                            {
                                "type": "spacer",
                                "layout": {
                                    "h": {
                                        "grow": 1
                                    }
                                }
                            }
                        ]
                    },
                    {
                        "type": "frame",
                        "layout": {
                            "h": {
                                "grow": 1
                            },
                            "gap": 4,
                            "align": "stretch"
                        },
                        "bind": {
                            "visible": "tab_mods"
                        },
                        "children": [
                            {
                                "id": "mod_scroll",
                                "type": "scroll",
                                "axis": "vertical",
                                "layout": {
                                    "h": {
                                        "grow": 1
                                    },
                                    "pad": [
                                        1,
                                        1,
                                        1,
                                        1
                                    ],
                                    "min_h": 36
                                },
                                "style": "panel.inset",
                                "children": [
                                    {
                                        "id": "mods",
                                        "type": "list",
                                        "layout": {
                                            "gap": 2,
                                            "align": "stretch"
                                        },
                                        "bind": {
                                            "items": "mod_rows",
                                            "selected": "mod_sel"
                                        },
                                        "children": [
                                            {
                                                "type": "row",
                                                "layout": {
                                                    "pad": [
                                                        3,
                                                        1,
                                                        3,
                                                        1
                                                    ],
                                                    "gap": 8,
                                                    "align": "center"
                                                },
                                                "style": "list.row",
                                                "children": [
                                                    {
                                                        "type": "image",
                                                        "image": "",
                                                        "layout": {
                                                            "w": 16,
                                                            "h": 16
                                                        },
                                                        "bind": {
                                                            "visible": "has_icon",
                                                            "image": "icon"
                                                        }
                                                    },
                                                    {
                                                        "type": "column",
                                                        "layout": {
                                                            "gap": 2
                                                        },
                                                        "children": [
                                                            {
                                                                "type": "row",
                                                                "layout": {
                                                                    "gap": 5,
                                                                    "align": "center"
                                                                },
                                                                "children": [
                                                                    {
                                                                        "type": "label",
                                                                        "bind": {
                                                                            "text": "name"
                                                                        }
                                                                    },
                                                                    {
                                                                        "type": "badge",
                                                                        "bind": {
                                                                            "text": "version",
                                                                            "visible": "has_version"
                                                                        }
                                                                    }
                                                                ]
                                                            },
                                                            {
                                                                "type": "label",
                                                                "style": "label.muted",
                                                                "bind": {
                                                                    "text": "desc"
                                                                }
                                                            }
                                                        ]
                                                    },
                                                    {
                                                        "type": "spacer",
                                                        "layout": {
                                                            "w": {
                                                                "grow": 1
                                                            }
                                                        }
                                                    },
                                                    {
                                                        "id": "mod_on",
                                                        "type": "toggle",
                                                        "bind": {
                                                            "value": "enabled",
                                                            "enabled": "toggleable",
                                                            "visible": "toggleable"
                                                        }
                                                    },
                                                    {
                                                        "type": "badge",
                                                        "text": "always on",
                                                        "bind": {
                                                            "visible": "content_only"
                                                        }
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "type": "label",
                                "text": "No mod packs installed",
                                "bind": {
                                    "visible": "no_mods"
                                }
                            },
                            {
                                "type": "alert",
                                "level": "info",
                                "text": "Changes to mods will apply the next time you load this world."
                            }
                        ]
                    },
                    {
                        "type": "row",
                        "layout": {
                            "gap": 5
                        },
                        "children": [
                            {
                                "id": "back",
                                "type": "button",
                                "text": "Back",
                                "layout": {
                                    "w": 90
                                }
                            },
                            {
                                "type": "spacer",
                                "layout": {
                                    "w": {
                                        "grow": 1
                                    }
                                }
                            },
                            {
                                "id": "delete_world",
                                "type": "button",
                                "text": "Delete World",
                                "layout": {
                                    "w": 110
                                },
                                "style": "button.danger"
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
