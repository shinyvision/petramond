{
    "format": 1,
    "kind": "petramond:create_world",
    "class": "screen",
    "root": {
        "type": "frame",
        "layout": {
            "w": {
                "grow": 1
            },
            "h": {
                "grow": 1
            },
            "align": "center",
            "justify": "center"
        },
        "children": [
            {
                "type": "image",
                "image": "../../textures/gui/screenshot.png",
                "fit": "cover",
                "layout": {
                    "w": {
                        "grow": 1
                    },
                    "h": {
                        "grow": 1
                    },
                    "abs": {
                        "x": 0,
                        "y": 0
                    }
                }
            },
            {
                "type": "frame",
                "style": "panel.large",
                "layout": {
                    "w": 300,
                    "h": 240,
                    "pad": [
                        4,
                        2,
                        4,
                        4
                    ],
                    "gap": 6,
                    "align": "stretch"
                },
                "children": [
                    {
                        "type": "label",
                        "text": "Create New World",
                        "scale": 2
                    },
                    {
                        "id": "tabs",
                        "type": "tab_bar",
                        "tabs": [
                            {
                                "key": "world",
                                "icon": "icon.tab_world",
                                "label": "World"
                            },
                            {
                                "key": "mods",
                                "icon": "icon.tab_mods",
                                "label": "Mods"
                            }
                        ],
                        "bind": {
                            "selected": "tab_sel"
                        }
                    },
                    {
                        "type": "frame",
                        "layout": {
                            "h": {
                                "grow": 1
                            },
                            "gap": 6,
                            "align": "stretch"
                        },
                        "bind": {
                            "visible": "tab_world"
                        },
                        "children": [
                            {
                                "type": "label",
                                "text": "World Name",
                                "style": "label.muted"
                            },
                            {
                                "type": "text_input",
                                "id": "create_name",
                                "placeholder": "My World",
                                "max_chars": 48,
                                "bind": {
                                    "text": "create_name"
                                }
                            },
                            {
                                "type": "label",
                                "text": "Name already exists",
                                "bind": {
                                    "visible": "name_exists"
                                },
                                "style": "label.danger"
                            },
                            {
                                "type": "label",
                                "text": "Seed",
                                "style": "label.muted"
                            },
                            {
                                "type": "text_input",
                                "id": "create_seed",
                                "placeholder": "Blank = random",
                                "max_chars": 48,
                                "bind": {
                                    "text": "create_seed"
                                }
                            },
                            {
                                "type": "spacer",
                                "layout": {
                                    "h": {
                                        "grow": 1
                                    }
                                }
                            }
                        ]
                    },
                    {
                        "type": "frame",
                        "layout": {
                            "h": {
                                "grow": 1
                            },
                            "gap": 4,
                            "align": "stretch"
                        },
                        "bind": {
                            "visible": "tab_mods"
                        },
                        "children": [
                            {
                                "id": "mod_scroll",
                                "type": "scroll",
                                "axis": "vertical",
                                "layout": {
                                    "h": {
                                        "grow": 1
                                    },
                                    "pad": [
                                        1,
                                        1,
                                        1,
                                        1
                                    ],
                                    "min_h": 36
                                },
                                "style": "panel.inset",
                                "children": [
                                    {
                                        "id": "mods",
                                        "type": "list",
                                        "layout": {
                                            "gap": 2,
                                            "align": "stretch"
                                        },
                                        "bind": {
                                            "items": "mod_rows",
                                            "selected": "mod_sel"
                                        },
                                        "children": [
                                            {
                                                "type": "row",
                                                "layout": {
                                                    "pad": [
                                                        3,
                                                        1,
                                                        3,
                                                        1
                                                    ],
                                                    "gap": 8,
                                                    "align": "center"
                                                },
                                                "style": "list.row",
                                                "children": [
                                                    {
                                                        "type": "image",
                                                        "image": "",
                                                        "layout": {
                                                            "w": 16,
                                                            "h": 16
                                                        },
                                                        "bind": {
                                                            "visible": "has_icon",
                                                            "image": "icon"
                                                        }
                                                    },
                                                    {
                                                        "type": "column",
                                                        "layout": {
                                                            "gap": 2
                                                        },
                                                        "children": [
                                                            {
                                                                "type": "row",
                                                                "layout": {
                                                                    "gap": 5,
                                                                    "align": "center"
                                                                },
                                                                "children": [
                                                                    {
                                                                        "type": "label",
                                                                        "bind": {
                                                                            "text": "name"
                                                                        }
                                                                    },
                                                                    {
                                                                        "type": "badge",
                                                                        "bind": {
                                                                            "text": "version",
                                                                            "visible": "has_version"
                                                                        }
                                                                    }
                                                                ]
                                                            },
                                                            {
                                                                "type": "label",
                                                                "style": "label.muted",
                                                                "bind": {
                                                                    "text": "desc"
                                                                }
                                                            }
                                                        ]
                                                    },
                                                    {
                                                        "type": "spacer",
                                                        "layout": {
                                                            "w": {
                                                                "grow": 1
                                                            }
                                                        }
                                                    },
                                                    {
                                                        "id": "mod_on",
                                                        "type": "toggle",
                                                        "bind": {
                                                            "value": "enabled",
                                                            "enabled": "toggleable",
                                                            "visible": "toggleable"
                                                        }
                                                    },
                                                    {
                                                        "type": "badge",
                                                        "text": "always on",
                                                        "bind": {
                                                            "visible": "content_only"
                                                        }
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "type": "label",
                                "text": "No mod packs installed",
                                "bind": {
                                    "visible": "no_mods"
                                }
                            },
                            {
                                "type": "alert",
                                "level": "info",
                                "text": "You can change these later in World Settings."
                            }
                        ]
                    },
                    {
                        "type": "row",
                        "layout": {
                            "gap": 5,
                            "align": "stretch"
                        },
                        "children": [
                            {
                                "type": "button",
                                "id": "create",
                                "text": "Create",
                                "style": "button.success",
                                "layout": {
                                    "w": {
                                        "grow": 1
                                    }
                                },
                                "bind": {
                                    "enabled": "can_create"
                                }
                            },
                            {
                                "type": "button",
                                "id": "cancel",
                                "text": "Cancel",
                                "layout": {
                                    "w": {
                                        "grow": 1
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
