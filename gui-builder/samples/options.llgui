{
  "version": 2,
  "document": {
    "format": 1,
    "kind": "petramond:options",
    "class": "screen",
    "root": {
      "type": "frame",
      "layout": {
        "w": {
          "grow": 1
        },
        "h": {
          "grow": 1
        },
        "pad": [
          0,
