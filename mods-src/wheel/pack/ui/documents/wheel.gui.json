{
    "format": 1,
    "kind": "wheel:wheel",
    "class": "container",
    "root": {
        "type": "frame",
        "style": "panel.large",
        "layout": {
            "pad": [
                4,
                2,
                4,
                4
            ],
            "gap": 6,
            "align": "center"
        },
        "children": [
            {
                "type": "frame",
                "layout": {
                    "w": 96,
                    "h": 104
                },
                "children": [
                    {
                        "type": "rotimage",
                        "image": "wheel_face_gui.png",
                        "layout": {
                            "w": 96,
                            "h": 96,
                            "abs": {
                                "x": 0,
                                "y": 8
                            }
                        },
                        "bind": {
                            "value": "wheel:angle"
                        }
                    },
                    {
                        "type": "image",
                        "image": "wheel_pointer.png",
                        "layout": {
                            "w": 12,
                            "h": 15,
                            "abs": {
                                "x": 42,
                                "y": 0
                            }
                        }
                    }
                ]
            },
            {
                "type": "label",
                "bind": {
                    "text": "wheel:result"
                },
                "text": " "
            },
            {
                "type": "button",
                "id": "spin",
                "text": "SPIN",
                "style": "button.success",
                "layout": {
                    "w": 70
                }
            }
        ]
    }
}